# Config files with secrets
# =============================================================================
settings.toml
my_game.toml
config.toml

# =============================================================================
# Ren'Py — engine SDK + game runtime artifacts
# =============================================================================
# Compiled script bytecode (regenerated from .rpy / .rpym sources)
*.rpyc
*.rpymc

# Ren'Py SDK / launcher (when cloned into the repo for local testing)
/renpy/
renpy.sh
renpy.exe
renpy.app/

# Game runtime state
game/saves/
game/cache/
persistent/
tmp/

# Runtime logs & diagnostics
log.txt
errors.txt
traceback.txt
exception.txt
lint.txt
reload.txt

# Build / packaging output
.android.json
archive.txt

# =============================================================================
# Godot — editor cache & exported builds
# =============================================================================
# Godot 4.x editor cache (generated, machine-specific)
.godot/

# Godot 3.x import cache (generated, machine-specific)
# Note: *.import source files are NOT ignored — only the .import/ cache dir.
.import/

# Exported binaries (regenerable from project source)
export/

# =============================================================================
# Local planning / dev notes (not for version control)
# =============================================================================
PLANNING/